    try { Set-ItemProperty -Path "HKCU:\Software\Microsoft\Windows\CurrentVersion\BackgroundAccessApplications" -Name "GlobalUserDisabled" -Value 0 -ErrorAction SilentlyContinue } catch { }
    Write-Host "[+] Update services enabled and started." -ForegroundColor Green
    Pause
}

# --- פונקציית מיתוג וביטול שירותי אבטחה (SmokeyTweaksDisDef) ---
function Disable-Defender {
    Clear-Host
    Write-Host "--- SMOKEY TWEAKS: KILLING ALL SECURITY SYSTEMS ---" -ForegroundColor Red -BackgroundColor Black
    Write-Host "DELETING DEFENDER FROM SETTINGS AND CORE..." -ForegroundColor Yellow

    # 1. ביטול מוחלט של ה-Defender (Policies)
    $Paths = @(
        "HKLM:\SOFTWARE\Policies\Microsoft\Windows Defender",
        "HKLM:\SOFTWARE\Policies\Microsoft\Windows Defender\Real-Time Protection",
        "HKLM:\SOFTWARE\Policies\Microsoft\Windows Defender\Spynet"
    )
    foreach ($Path in $Paths) { if (!(Test-Path $Path)) { New-Item $Path -Force | Out-Null } }

    Set-ItemProperty -Path "HKLM:\SOFTWARE\Policies\Microsoft\Windows Defender" -Name "DisableAntiSpyware" -Value 1
    Set-ItemProperty -Path "HKLM:\SOFTWARE\Policies\Microsoft\Windows Defender" -Name "DisableAntiVirus" -Value 1
    Set-ItemProperty -Path "HKLM:\SOFTWARE\Policies\Microsoft\Windows Defender\Real-Time Protection" -Name "DisableRealtimeMonitoring" -Value 1
    Set-ItemProperty -Path "HKLM:\SOFTWARE\Policies\Microsoft\Windows Defender\Spynet" -Name "SubmitSamplesConsent" -Value 2

    # 2. הסרת "Windows Security" מהגדרות הווינדוס (הגדרות האבטחה ייעלמו מהתפריט)
    Write-Host "[+] Removing Security Health from Settings..." -ForegroundColor Cyan
    $UIPath = "HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\Explorer\ControlPanel\NameSpace\{bb06c0e4-d293-4f75-8a90-cb05b6477eee}"
    if (Test-Path $UIPath) { Remove-Item $UIPath -Recurse -Force -ErrorAction SilentlyContinue }
    
    # הסתרת סמל האבטחה מה-Systray (ליד השעון)
    Set-ItemProperty -Path "HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\Run" -Name "SecurityHealth" -Value "" -ErrorAction SilentlyContinue

    # 3. ביטול SmartScreen ו-UAC (מניעת הודעות קופצות)
    Write-Host "[+] Killing SmartScreen & UAC..." -ForegroundColor Cyan
    Set-ItemProperty -Path "HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\Explorer" -Name "SmartScreenEnabled" -Value "Off"
    Set-ItemProperty -Path "HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\Policies\System" -Name "EnableLUA" -Value 0

    # 4. שיתוק שירותי המערכת (Services) דרך ה-Registry
    # אנחנו משנים את ה-Start ל-4 (Disabled) ישירות ברגיסטרי כי הווינדוס חוסם פקודות SC רגילות
    Write-Host "[+] Disabling Services via Registry (Deep)..." -ForegroundColor Cyan
    $Services = @("WinDefend", "WdNisSvc", "Sense", "wscsvc", "mpssvc", "SecurityHealthService")
    foreach ($Svc in $Services) {
        $SvcPath = "HKLM:\SYSTEM\CurrentControlSet\Services\$Svc"
        if (Test-Path $SvcPath) {
            Set-ItemProperty -Path $SvcPath -Name "Start" -Value 4 -ErrorAction SilentlyContinue
        }
    }

    # 5. ביטול Core Isolation (VBS) - ה-Tweak הכי חשוב ל-FPS
    Write-Host "[+] Disabling Virtualization Based Security..." -ForegroundColor Yellow
    Set-ItemProperty -Path "HKLM:\SYSTEM\CurrentControlSet\Control\DeviceGuard\Scenarios\HypervisorEnforcedCodeIntegrity" -Name "Enabled" -Value 0

    Write-Host "`nSYSTEM PURGED SUCCESSFULLY." -ForegroundColor Green
    Write-Host "RESTART REQUIRED to apply all changes." -ForegroundColor White
    
    # הודעת אזהרה סופית ב-GUI (אם תרצה)
    # [System.Windows.Forms.MessageBox]::Show("Security is gone. Restart your PC now.")
}

function Disable-CoreIsolation {
    Clear-Host
    Write-Host "=== DISABLE CORE ISOLATION (HVCI) ===" -ForegroundColor Red
    $confirm = Read-Host "This will disable Memory Integrity for better CPU performance. Type 'YES' to continue"
    if ($confirm -ne 'YES') { Write-Host "Aborted." -ForegroundColor Yellow; Pause; return }

    try {
        Write-Host "[*] Modifying Kernel Virtualization settings..." -ForegroundColor Gray
        
        # הנתיב ברישום שאחראי על בידוד ליבה (Memory Integrity)
        $vbsPath = "HKLM:\SYSTEM\CurrentControlSet\Control\DeviceGuard\Scenarios\HypervisorEnforcedCodeIntegrity"
        
        if (!(Test-Path $vbsPath)) { 
            New-Item -Path $vbsPath -Force | Out-Null 
        }

        # הגדרת הערך ל-0 (מבוטל)
        Set-ItemProperty -Path $vbsPath -Name "Enabled" -Value 0 -Type DWord -Force
        
        # ביטול Virtualization-Based Security (VBS) באופן כללי
        $dgPath = "HKLM:\SYSTEM\CurrentControlSet\Control\DeviceGuard"
        Set-ItemProperty -Path $dgPath -Name "EnableVirtualizationBasedSecurity" -Value 0 -Type DWord -Force

        Write-Host "[+] Core Isolation (HVCI) has been disabled." -ForegroundColor Green
        Write-Host "[!] A REBOOT is required for changes to take effect." -ForegroundColor Cyan
    } catch {
        Write-Host "[!] Failed to modify Registry: $($_.Exception.Message)" -ForegroundColor Red
    }
    Pause
}

