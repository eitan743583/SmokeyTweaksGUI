# Simple error logging to help diagnose crashes when running as EXE
$LogFile = Join-Path $env:TEMP 'SmokeyTweaks_error.log'
function Log-Error {
    param($Err)
    try {
        $entry = "========================================`n"
        $entry += "Time: $(Get-Date -Format o)`n"
        $entry += ($Err | Out-String)
        $entry += "`n"
        Add-Content -Path $LogFile -Value $entry -ErrorAction SilentlyContinue
    } catch { }
}

# Global trap to capture otherwise-unhandled errors
trap {
    Log-Error $_
    Write-Host "`n[!] Fatal error occurred. Details written to: $LogFile" -ForegroundColor Red
    Pause
    break
}

