    $allServices = @("SysMain", "WSearch", "Spooler", "DiagTrack", "MapsBroker", "PcaSvc", "WerSvc", "WbioSrvc", "TabletInputService", "Fax", "XblAuthManager", "XblGameSave", "XboxNetApiSvc", "XboxGipSvc", "bthserv", "BTHPORT", "wisvc", "dosvc", "edgeupdate", "edgeupdatem", "PhoneSvc", "lmhosts", "W32Time", "iphlpsvc", "QWAVE")
    $disableServices = @("XblAuthManager", "XblGameSave", "XboxNetApiSvc", "XboxGipSvc", "dmwappushservice", "WerSvc", "Spooler", "WbioSrvc", "TabletInputService", "SysMain")

    $table = @()
    foreach ($s in $allServices) {
        $svc = Get-Service -Name $s -ErrorAction SilentlyContinue
        if ($null -ne $svc) {
            $state = $svc.Status
            $cim = Get-CimInstance -ClassName Win32_Service -Filter "Name='$s'" -ErrorAction SilentlyContinue
            $startType = if ($cim) { $cim.StartMode } else { 'N/A' }
