function Remove-Edge {
    Clear-Host
    Write-Host "=== REMOVE MICROSOFT EDGE ===" -ForegroundColor Magenta
    $confirm = Read-Host "This will attempt to uninstall Microsoft Edge. Type 'YES' to continue"
    if ($confirm -ne 'YES') { Write-Host "Aborted." -ForegroundColor Yellow; Pause; return }

    try {
        Write-Host "[1/8] Attempting winget uninstall (if available)..." -ForegroundColor Cyan
        if (Get-Command winget -ErrorAction SilentlyContinue) {
            try {
                & winget uninstall --id "Microsoft.Edge" --accept-package-agreements --accept-source-agreements 2>&1 | Write-Host
            } catch {
                Write-Host "winget uninstall failed or not available for this Edge package." -ForegroundColor Yellow
            }
        } else {
            Write-Host "winget not found, skipping." -ForegroundColor Yellow
        }

        Write-Host "[2/8] Stopping Edge processes..." -ForegroundColor Cyan
        Get-Process -Name msedge -ErrorAction SilentlyContinue | ForEach-Object { try { Stop-Process -Id $_.Id -Force -ErrorAction SilentlyContinue } catch { } }

        $possiblePaths = @(
            'C:\Program Files\Microsoft\Edge\Application',
            'C:\Program Files (x86)\Microsoft\Edge\Application'
        )
        foreach ($base in $possiblePaths) {
            if (Test-Path $base) {
                Write-Host "[3/8] Looking for Edge versions under $base" -ForegroundColor Cyan
                $versions = Get-ChildItem -Path $base -Directory -ErrorAction SilentlyContinue | Sort-Object Name -Descending
                foreach ($v in $versions) {
                    $setup = Join-Path $v.FullName 'Installer\setup.exe'
                    if (Test-Path $setup) {
                        Write-Host "Running setup uninstall for version $($v.Name) at $setup" -ForegroundColor Cyan
                        try {
                            Start-Process -FilePath $setup -ArgumentList '--uninstall','--system-level','--verbose-logging','--force-uninstall' -Wait -NoNewWindow -ErrorAction Stop
                            Write-Host "Uninstall attempted via setup.exe for $($v.Name)." -ForegroundColor Green
                        } catch {
                            Write-Host "Failed to run setup.exe for $($v.Name): $($_.Exception.Message)" -ForegroundColor Yellow
                        }
                    }
                }
            }
        }

        Write-Host "[4/8] Removing Edge Update scheduled tasks (if any)..." -ForegroundColor Cyan
        try {
            Get-ScheduledTask -ErrorAction SilentlyContinue | Where-Object { $_.TaskName -like '*edge*' -or $_.TaskName -like '*Edge*' } | ForEach-Object {
                try { Unregister-ScheduledTask -TaskName $_.TaskName -Confirm:$false -ErrorAction SilentlyContinue } catch { }
            }
        } catch { }

        Write-Host "[5/8] Stopping and removing Edge Update services..." -ForegroundColor Cyan
        $svcNames = @('edgeupdate', 'edgeupdatem')
        foreach ($s in $svcNames) {
            if (Get-Service -Name $s -ErrorAction SilentlyContinue) {
                try { Stop-Service -Name $s -Force -ErrorAction SilentlyContinue } catch { }
                try { sc.exe delete $s | Out-Null } catch { }
            }
        }

        Write-Host "[6/8] Removing Edge program folders (may require admin rights)..." -ForegroundColor Cyan
        $folders = @(
            'C:\Program Files\Microsoft\Edge',
            'C:\Program Files (x86)\Microsoft\Edge',
            'C:\Program Files\Microsoft\EdgeUpdate',
            'C:\Program Files (x86)\Microsoft\EdgeUpdate',
            "$env:LOCALAPPDATA\Microsoft\Edge",
            "$env:PROGRAMDATA\Microsoft\Edge"
        )
        foreach ($f in $folders) {
            try {
                if (Test-Path $f) { Remove-Item -Path $f -Recurse -Force -ErrorAction SilentlyContinue }
            } catch { }
        }

        Write-Host "[7/8] Removing Edge policy registry keys if exist..." -ForegroundColor Cyan
        $polKeys = @('HKLM:\SOFTWARE\Policies\Microsoft\Edge', 'HKCU:\SOFTWARE\Policies\Microsoft\Edge')
        foreach ($k in $polKeys) { if (Test-Path $k) { Remove-Item -Path $k -Recurse -Force -ErrorAction SilentlyContinue } }

        Write-Host "[8/8] Attempting to remove Appx packages (if any)..." -ForegroundColor Cyan
        try {
            Get-AppxPackage -AllUsers | Where-Object { $_.Name -like '*MicrosoftEdge*' -or $_.Name -like '*Microsoft.MicrosoftEdge*' } | ForEach-Object {
                try { Remove-AppxPackage -Package $_.PackageFullName -ErrorAction SilentlyContinue } catch { }
            }
        } catch { }

        Write-Host "`n[+] Edge uninstall/cleanup attempted. Some components may remain; a reboot is recommended." -ForegroundColor Green
    } catch {
        Write-Host "[!] An error occurred while attempting to remove Edge: $($_.Exception.Message)" -ForegroundColor Red
    }
    Pause
}

function Show-LowProcesses {
