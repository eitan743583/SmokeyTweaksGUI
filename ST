                }
                default { Set-Service -Name $name -StartupType Manual -ErrorAction SilentlyContinue }
            }
            Write-Host ("[OK] {0} -> {1}" -f $name, $target) -ForegroundColor Green
        } catch {
            Write-Host ("[ERR] Failed to set {0}: {1}" -f $name, $_.Exception.Message) -ForegroundColor Red
        }
    }

    Write-Host "`n[+] Service startup types applied. Some changes may require reboot." -ForegroundColor Cyan
    Pause
}

