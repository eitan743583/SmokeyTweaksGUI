function Create-Smokey-Restore {
    Write-Host "`n[*] Creating System Restore Point: SMOKEY TWEAKS..." -ForegroundColor Cyan

    # Ensure relevant services are available
    $srService = Get-Service -Name 'srservice' -ErrorAction SilentlyContinue
    $vssService = Get-Service -Name 'VSS' -ErrorAction SilentlyContinue
    if ($srService -and $srService.Status -ne 'Running') {
        try { Start-Service -Name 'srservice' -ErrorAction SilentlyContinue } catch { }
    }
    if ($vssService -and $vssService.Status -ne 'Running') {
        try { Start-Service -Name 'VSS' -ErrorAction SilentlyContinue } catch { }
    }

    # Try Checkpoint-Computer first
    if (Get-Command Checkpoint-Computer -ErrorAction SilentlyContinue) {
        try {
            Checkpoint-Computer -Description 'SMOKEY TWEAKS' -RestorePointType 'MODIFY_SETTINGS' -ErrorAction Stop
            Write-Host '[+] Restore Point Created Successfully.' -ForegroundColor Green
            Pause
            return
        } catch {
            Write-Host "[!] Checkpoint-Computer failed: $($_.Exception.Message)" -ForegroundColor Yellow
        }
    }

    # WMI fallback using SystemRestore class
    try {
        $sr = [wmiclass]'root\default:systemrestore'
        $ret = $sr.CreateRestorePoint('SMOKEY TWEAKS', 12, 100)
        if ($ret -eq 0) {
            Write-Host '[+] Restore Point Created Successfully (WMI).' -ForegroundColor Green
        } else {
            Write-Host "[!] WMI CreateRestorePoint returned code: $ret" -ForegroundColor Yellow
            Write-Host "[i] Common causes: System Protection disabled for system drive, insufficient shadow storage, or service disabled." -ForegroundColor Cyan
        }
    } catch {
        Write-Host "[!] WMI CreateRestorePoint failed: $($_.Exception.Message)" -ForegroundColor Red
        Write-Host "[i] Ensure System Protection is enabled for the system drive and Volume Shadow Copy / System Restore services are running." -ForegroundColor Yellow
    }
    Pause
}

