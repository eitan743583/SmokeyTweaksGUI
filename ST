function Enable-Updates {
    Clear-Host
    Write-Host "=== ENABLE WINDOWS UPDATES ===" -ForegroundColor Cyan
    $confirm = Read-Host "This will enable Windows Update services and start them. Type 'YES' to continue"
    if ($confirm -ne 'YES') { Write-Host "Aborted." -ForegroundColor Yellow; Pause; return }

    $upd = @("wuauserv", "bits", "dosvc", "UsoSvc")
    foreach ($s in $upd) {
        try { Set-Service -Name $s -StartupType Manual -ErrorAction SilentlyContinue } catch { }
        try { Start-Service -Name $s -ErrorAction SilentlyContinue } catch { }
