function Run-Disable-StartupApps {
Write-Host "=== DISABLING ALL STARTUP APPS (Task Manager) ===" -ForegroundColor Cyan
    
    $approvedPaths = @(
        "HKCU:\Software\Microsoft\Windows\CurrentVersion\Explorer\StartupApproved\Run",
        "HKCU:\Software\Microsoft\Windows\CurrentVersion\Explorer\StartupApproved\Run32",
        "HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\Explorer\StartupApproved\Run",
        "HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\Explorer\StartupApproved\Run32"
    )

    # מערך בינארי שמייצג "Disabled" (12 בייטים)
    $disabledByte = [byte[]](0x03, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00)

    foreach ($path in $approvedPaths) {
        if (Test-Path $path) {
            $items = Get-Item -Path $path
            foreach ($valName in $items.GetValueNames()) {
                # בדיקה אם זה כבר Disabled (מתחיל ב-03)
                $currentVal = Get-ItemProperty -Path $path -Name $valName | Select-Object -ExpandProperty $valName
                if ($currentVal[0] -ne 0x03) {
                    Write-Host "[-] Disabling: $valName" -ForegroundColor Yellow
                    Set-ItemProperty -Path $path -Name $valName -Value $disabledByte
                }
            }
        }

        $startupUser = [Environment]::GetFolderPath('Startup')
        $startupAll = Join-Path $env:ProgramData 'Microsoft\Windows\Start Menu\Programs\StartUp'
        foreach ($f in @($startupUser, $startupAll)) {
            if (Test-Path $f) {
                Get-ChildItem -Path $f -File -ErrorAction SilentlyContinue | ForEach-Object {
                    $items += [PSCustomObject]@{ Type = 'StartupFile'; Hive = $null; Path = $_.FullName; Name = $_.Name; Value = $_.FullName }
                }
            }
        }

        if ($items.Count -eq 0) { Write-Host "No startup entries found." -ForegroundColor Yellow; Pause; return }

        Write-Host "Found the following startup entries:`n" -ForegroundColor Cyan
        for ($i = 0; $i -lt $items.Count; $i++) {
            $it = $items[$i]
            if ($it.Type -eq 'Registry') {
                Write-Host (" [{0}] [REG] {1}\{2} -> {3}" -f $i, $it.Hive, $it.Name, $it.Value)
            } else {
                Write-Host (" [{0}] [FILE] {1}" -f $i, $it.Path)
            }
        }

        $sel = Read-Host "Enter numbers separated by commas to disable, or type 'all' to disable all, or press Enter to cancel"
        if ([string]::IsNullOrWhiteSpace($sel)) { Write-Host "Aborted." -ForegroundColor Yellow; Pause; return }
        if ($sel -eq 'all') { $indexes = 0..($items.Count - 1) } else { $indexes = $sel -split ',' | ForEach-Object { $_.Trim() } | Where-Object { $_ -match '^[0-9]+$' } | ForEach-Object { [int]$_ } }

        foreach ($idx in $indexes) {
            if ($idx -ge 0 -and $idx -lt $items.Count) {
                $entry = $items[$idx]
                if ($entry.Type -eq 'Registry') {
                    $disabledKey = ($entry.Path -replace '\\Run$','\\RunDisabled')
                    if (!(Test-Path $disabledKey)) { New-Item -Path $disabledKey -Force | Out-Null }
                    Set-ItemProperty -Path $disabledKey -Name $entry.Name -Value $entry.Value -Type String -ErrorAction SilentlyContinue
                    Remove-ItemProperty -Path $entry.Path -Name $entry.Name -ErrorAction SilentlyContinue
                    Write-Host ("[DISABLED] Registry: {0}\{1}" -f $entry.Path, $entry.Name) -ForegroundColor Green
                } else {
                    $destFolder = Join-Path (Split-Path $entry.Path) 'Startup.Disabled'
                    if (!(Test-Path $destFolder)) { New-Item -ItemType Directory -Path $destFolder -Force | Out-Null }
                    $dest = Join-Path $destFolder $entry.Name
                    Move-Item -Path $entry.Path -Destination $dest -Force -ErrorAction SilentlyContinue
                    Write-Host ("[DISABLED] Startup file moved: {0} -> {1}" -f $entry.Path, $dest) -ForegroundColor Green
                }
            }
        }

        Write-Host "`n[+] Selected startup entries disabled. A reboot may be required for some changes." -ForegroundColor Cyan
    } catch {
        Write-Host "[!] Error while disabling startup apps: $($_.Exception.Message)" -ForegroundColor Red
    }
    Pause
}

function Show-HardwareMonitor {
    Clear-Host
    Write-Host "=== HARDWARE MONITOR (press Q to quit) ===" -ForegroundColor Cyan
    while ($true) {
        try {
            $cpuSample = Get-Counter '\Processor(_Total)\% Processor Time' -ErrorAction SilentlyContinue
            $cpu = if ($cpuSample.CounterSamples) { $cpuSample.CounterSamples.CookedValue } else { 0 }
        } catch { $cpu = 0 }
        $os = Get-CimInstance -ClassName Win32_OperatingSystem
        $totalMemKB = [double]$os.TotalVisibleMemorySize
        $freeMemKB = [double]$os.FreePhysicalMemory
        $usedMemMB = [math]::Round((($totalMemKB - $freeMemKB) / 1024),2)
        $totalMemMB = [math]::Round(($totalMemKB / 1024),2)

        $disks = Get-CimInstance -ClassName Win32_LogicalDisk | Where-Object { $_.DriveType -eq 3 }

        $topProcs = Get-Process -ErrorAction SilentlyContinue | Sort-Object CPU -Descending | Select-Object -First 5 -Property Id, ProcessName, CPU, WS

        Clear-Host
        Write-Host ("Time: {0}" -f (Get-Date)) -ForegroundColor Yellow
        Write-Host ("CPU Usage: {0:N1}%" -f $cpu) -ForegroundColor Green
        Write-Host ("Memory: {0} MB used of {1} MB" -f $usedMemMB, $totalMemMB) -ForegroundColor Green
        Write-Host "Disks:" -ForegroundColor Cyan
        foreach ($d in $disks) {
            if ($d.Size -and $d.FreeSpace) {
                $sizeGB = [math]::Round($d.Size / 1GB, 2)
                $freeGB = [math]::Round($d.FreeSpace/1GB,2)
                $usedPct = [math]::Round(((($d.Size - $d.FreeSpace)/$d.Size)*100),2)
                Write-Host (" {0}: {1} GB free of {2} GB ({3}% used)" -f $d.DeviceID, $freeGB, $sizeGB, $usedPct)
            }
        }
        Write-Host "`nTop Processes by CPU (Id, Name, CPU, WS):" -ForegroundColor Cyan
        foreach ($p in $topProcs) {
            $wsMB = [math]::Round($p.WS/1MB,2)
            Write-Host (" {0} {1} CPU:{2} WS:{3}MB" -f $p.Id, $p.ProcessName, $p.CPU, $wsMB)
        }

        Write-Host "`nPress 'Q' to return to menu..." -ForegroundColor Yellow
        Start-Sleep -Seconds 2
        try {
            if ($Host.UI.RawUI.KeyAvailable) {
                $key = $Host.UI.RawUI.ReadKey('NoEcho,IncludeKeyDown')
                if ($key.Character -eq 'q' -or $key.Character -eq 'Q') { break }
            }
        } catch {
            # Host may not support KeyAvailable; continue and rely on user to wait
        }
    }
}

